generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id                  BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  username            String       @unique(map: "uq_users_username") @db.VarChar(50)
  passwordHash        String       @map("password_hash") @db.VarChar(255)
  failedLoginAttempts Int          @default(0) @map("failed_login_attempts") @db.UnsignedInt
  lockoutUntil        DateTime?    @map("lockout_until") @db.DateTime(0)
  lastLoginAt         DateTime?    @map("last_login_at") @db.DateTime(0)
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime     @updatedAt @map("updated_at") @db.Timestamp(0)

  profile  Profile?
  sessions UserSession[]

  @@map("users")
}

model UserSession {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt   @map("user_id") @db.UnsignedBigInt
  tokenHash String   @unique(map: "uq_user_sessions_token_hash") @map("token_hash") @db.Char(64)
  expiresAt DateTime @map("expires_at") @db.DateTime(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_user_sessions_user")

  @@index([userId], map: "idx_user_sessions_user_id")
  @@index([expiresAt], map: "idx_user_sessions_expires_at")
  @@map("user_sessions")
}

model AuthRateLimit {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  scopeKey        String    @unique(map: "uq_auth_rate_limits_scope_key") @map("scope_key") @db.VarChar(191)
  attemptCount    Int       @default(0) @map("attempt_count") @db.UnsignedInt
  windowStartedAt DateTime  @map("window_started_at") @db.DateTime(0)
  blockedUntil    DateTime? @map("blocked_until") @db.DateTime(0)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([blockedUntil], map: "idx_auth_rate_limits_blocked_until")
  @@map("auth_rate_limits")
}

model Profile {
  id                BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId            BigInt   @unique(map: "uq_profiles_user_id") @map("user_id") @db.UnsignedBigInt
  profilePictureUrl String   @map("profile_picture_url") @db.VarChar(500)
  name              String   @db.VarChar(120)
  age               Int      @db.UnsignedTinyInt
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_profiles_user")

  @@index([userId], map: "idx_profiles_user_id")
  @@map("profiles")
}
